    title: "Static and Dynamic Pile Load Testing: Ensuring Structural Safety in Heavy Civil Projects",
    description:
        "Learn static & dynamic pile load testing methods to ensure foundation safety. Dwizzy Infra provides certified load testing for bridges, towers & railways.",
    author: "Dwizzy Infra Team",
    date: "2026-04-14",
    category: "Infrastructure",
    readTime: "9 min read",
    image: BlogImg,
    keywords: [
        "pile load testing",
        "static load testing",
        "dynamic load testing",
        "ASTM D4945",
        "ASTM D1143",
        "deep foundation testing",
        "Dwizzy Infra",
