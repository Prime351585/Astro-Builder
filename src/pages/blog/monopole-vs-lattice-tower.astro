---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import BlogImg from "../../assets/blogImages/Blog5.webp";

// Blog post metadata
const post = {
    title: "Monopole vs Lattice Tower: Which Structure Is Right for Your Project?",
    description:
        "Monopole vs lattice tower: compare structure, cost, installation time, and applications to choose the right tower for power transmission or telecom projects.",
    author: "Dwizzy Infra Team",
    date: "2026-03-24",
    category: "Infrastructure",
    readTime: "8 min read",
    image: BlogImg,
    keywords: [
        "monopole vs lattice tower",
        "power transmission towers",
        "telecom towers",
        "monopole tower",
        "lattice tower",
        "Dwizzy Infra",
    ],
};

// Structured data for SEO
const structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.title,
    description: post.description,
    image: `https://dwizzyinfra.com/blogImages/Blog5.webp`,
    datePublished: post.date,
    dateModified: post.date,
    author: {
        "@type": "Organization",
        name: post.author,
    },
    publisher: {
        "@type": "Organization",
        name: "Dwizzy Infra",
        logo: {
            "@type": "ImageObject",
            url: "https://dwizzyinfra.com/icon.webp",
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": "https://dwizzyinfra.com/blog/monopole-vs-lattice-tower/",
    },
};
---

<Layout
    title={`${post.title} - Dwizzy Infra Blog`}
    description={post.description}
>
    <!-- Structured Data for SEO -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
    />

    <main>
        <!-- Hero Section with Featured Image -->
        <section class="relative bg-black text-white py-20 overflow-hidden">
            <div
                class="absolute inset-0 bg-[url('/SliderImages/2.webp')] bg-cover bg-center opacity-30"
            >
            </div>
            <div
                class="absolute inset-0 bg-gradient-to-r from-black via-black/90 to-black/70"
            >
            </div>

            <div class="container mx-auto px-4 relative z-10">
                <!-- Breadcrumb Navigation -->
                <nav class="mb-8" aria-label="Breadcrumb">
                    <ol
                        class="flex items-center space-x-2 text-sm text-gray-300"
                        itemscope
                        itemtype="https://schema.org/BreadcrumbList"
                    >
