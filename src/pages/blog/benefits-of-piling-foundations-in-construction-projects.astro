    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.title,
    description: post.description,
    image: `https://dwizzyinfra.com/blogImages/Blog9.webp`,
    datePublished: post.date,
    dateModified: post.date,
    author: {
        "@type": "Organization",
        name: post.author,
    },
    publisher: {
        "@type": "Organization",
        name: "Dwizzy Infra",
        logo: {
            "@type": "ImageObject",
            url: "https://dwizzyinfra.com/icon.webp",
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": `https://dwizzyinfra.com/blog/benefits-of-piling-foundations-in-construction-projects/`,
